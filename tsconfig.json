{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "noEmit": false,           // Rollup 経由で型定義を出力させるために false に
    "declaration": true,       // 型定義を出力する
    "emitDeclarationOnly": true, // TSは型定義だけを担当し、JS本体は Rollup に任せる
    /* ------------- */ 
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "declarationDir": "build/types",// 型定義の保存先
    "rootDir": "src",
    "sourceMap": true,
    //"outDir": "build",
    "strict": true,
    "noImplicitAny": false,// ここを false にすると、引数の型省略が許されるようになります
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [],
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "react": ["./node_modules/react"],
      "react-dom": ["./node_modules/react-dom"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}